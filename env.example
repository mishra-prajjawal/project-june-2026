# Django security settings
DEBUG=True
SECRET_KEY=change_me_to_a_very_long_random_string_1234567890

# Database Connection URL (Supports mysql://, postgres://, and sqlite:///)
# MySQL Example: mysql://user:password@localhost:3306/foodconnect
# Postgres Example: postgres://user:password@localhost:5432/foodconnect
# SQLite (fallback) Example: sqlite:///db.sqlite3
DATABASE_URL=mysql://root:password@127.0.0.1:3306/foodconnect

# Allowed hosts (comma-separated list)
ALLOWED_HOSTS=localhost,127.0.0.1